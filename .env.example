# Stripe Connect — one platform key, multiple connected accounts
STRIPE_API_KEY=sk_live_...
STRIPE_ACCOUNT_SPARKRY=acct_...
STRIPE_ACCOUNT_BLACKLINE=acct_...
# Optional third account (Travis personal Stripe running Sparkry Substack subs).
# Ingested into entity=sparkry in PERSONAL_MIXED mode: only subscription /
# manual-invoice charges auto-classify; any other charge is flagged via
# review_reason so it surfaces for human review.
STRIPE_ACCOUNT_TRAVIS_PERSONAL=acct_...

# Stripe restricted key for Payment Links (write: Products, Prices, Payment Links)
STRIPE_RESTRICTED_KEY=rk_live_...

# Resend (invoice email delivery)
RESEND_API_KEY=re_...

# Shopify
SHOPIFY_API_KEY=...
SHOPIFY_API_SECRET=...
SHOPIFY_STORE_URL=e1ygfk-r8.myshopify.com

# Anthropic (classification + OCR)
ANTHROPIC_API_KEY=sk-ant-...

# Database path (default: data/accounting.db)
DATABASE_PATH=data/accounting.db

# n8n webhook secret (for Gmail ingest)
N8N_WEBHOOK_SECRET=...

# API key for dashboard → API authentication (leave unset to disable auth in local dev)
API_KEY=
